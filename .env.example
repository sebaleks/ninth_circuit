# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_BUCKET=bucket_name
MODEL_LABEL=gemini-2.5-pro
GOOGLE_APPLICATION_CREDENTIALS=.key_file_location
# Hugging Face (backup)
HF_TOKEN=your-huggingface-write-token
HF_REPO=vpal/asylum-cases

# CourtListener (fallback data source)
COURTLISTENER_TOKEN=your-courtlistener-api-token
